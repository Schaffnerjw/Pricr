# ── Proxy server (proxy.js) env vars ──
# Port the proxy listens on. Railway sets PORT automatically; 3001 is the local default.
PORT=3001
# Anthropic API key the proxy injects into requests to api.anthropic.com (REQUIRED).
ANTHROPIC_KEY=sk-ant-...

# ── Proxy → Supabase (REMOTE SIGNING PAGE; server-side only) ──
# The proxy uses these to read a quote by its signing token and write the customer's
# signature back. The SERVICE ROLE key is secret — it lives ONLY on the server (Railway)
# and is NEVER shipped in the app or exposed to the browser. Do not put it in .env.local.
# Get them from Supabase → Settings → API (the service_role key, not the anon key).
#
# Add these in Railway → your service → Variables (do NOT prefix with EXPO_PUBLIC_):
#   SUPABASE_URL=https://your-project.supabase.co
#   SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOi...   (service_role secret)
# Then redeploy. The remote signing page lives at  <proxy-url>/sign/<signing_token>.
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ── Proxy → Resend (signing-confirmation emails; server-side only) ──
# Transactional email for the signing audit trail (customer confirmation + contractor
# notification). Sign up at resend.com (free tier). The FROM_EMAIL domain MUST be verified
# in Resend → Domains before sending. These are server-only — do NOT prefix with EXPO_PUBLIC_.
# Add in Railway → your service → Variables, then redeploy:
#   RESEND_API_KEY=re_...
#   FROM_EMAIL=quotes@pricr.veraa.io   (must be on a Resend-verified domain)
# If RESEND_API_KEY is unset, signing still works — emails are simply skipped.
RESEND_API_KEY=re_your_resend_api_key
FROM_EMAIL=quotes@pricr.veraa.io

# ── Proxy → Twilio (SMS identity verification; server-side only) ──
# Sends the 6-digit signing code by SMS so the signer's identity is verified before signing.
# Get these from twilio.com → Console. TWILIO_PHONE_NUMBER must be an SMS-capable Twilio number
# in E.164 format (e.g. +15551234567). Server-only — do NOT prefix with EXPO_PUBLIC_.
# Add in Railway → your service → Variables, then redeploy:
#   TWILIO_ACCOUNT_SID=ACxxxxxxxx
#   TWILIO_AUTH_TOKEN=your-twilio-auth-token
#   TWILIO_PHONE_NUMBER=+15551234567
# If these are unset, SMS verification is skipped automatically and signing still works
# (the admin's "Require SMS verification" toggle only takes effect once Twilio is configured).
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your-twilio-auth-token
TWILIO_PHONE_NUMBER=+15551234567

# ── App (Expo) env vars ──
# Public base URL of the deployed proxy. Set this to your Railway URL.
EXPO_PUBLIC_PROXY_URL=https://your-railway-url.railway.app

# ── Supabase ──
# From Supabase project Settings → API. Without these, the app runs on local/demo flows only.
EXPO_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
