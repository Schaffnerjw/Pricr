# ── Proxy server (proxy.js) env vars ──
# Port the proxy listens on. Railway sets PORT automatically; 3001 is the local default.
PORT=3001
# Anthropic API key the proxy injects into requests to api.anthropic.com (REQUIRED).
ANTHROPIC_KEY=sk-ant-...

# ── Super-admin master code (server-side only; NO default) ──
# Gates the /admin/* endpoints. The client never compares this — it POSTs the entered code to
# /admin/auth, which does a timing-safe compare and returns a short-lived (4h) in-memory Bearer token.
# If MASTER_CODE is unset, ALL /admin/* endpoints return 503 "Admin not configured" (fail closed).
# Set this ONLY in Railway → Variables (do NOT prefix with EXPO_PUBLIC_; do NOT commit a real value).
# IMPORTANT: rotate this — the old hardcoded value (CB101919) is retired and must not be reused.
MASTER_CODE=choose-a-long-random-secret

# ── Proxy → Supabase (REMOTE SIGNING PAGE; server-side only) ──
# The proxy uses these to read a quote by its signing token and write the customer's
# signature back. The SERVICE ROLE key is secret — it lives ONLY on the server (Railway)
# and is NEVER shipped in the app or exposed to the browser. Do not put it in .env.local.
# Get them from Supabase → Settings → API (the service_role key, not the anon key).
#
# Add these in Railway → your service → Variables (do NOT prefix with EXPO_PUBLIC_):
#   SUPABASE_URL=https://your-project.supabase.co
#   SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOi...   (service_role secret)
# Then redeploy. The remote signing page lives at  <proxy-url>/sign/<signing_token>.
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ── Proxy → Resend (signing-confirmation emails; server-side only) ──
# Transactional email for the signing audit trail (customer confirmation + contractor
# notification). Sign up at resend.com (free tier). The FROM_EMAIL domain MUST be verified
# in Resend → Domains before sending. These are server-only — do NOT prefix with EXPO_PUBLIC_.
# Add in Railway → your service → Variables, then redeploy:
#   RESEND_API_KEY=re_...
#   FROM_EMAIL=quotes@pricr.veraa.io   (must be on a Resend-verified domain)
# If RESEND_API_KEY is unset, signing still works — emails are simply skipped.
RESEND_API_KEY=re_your_resend_api_key
FROM_EMAIL=quotes@pricr.veraa.io

# ── Proxy → Twilio (SMS identity verification; server-side only) ──
# Sends the 6-digit signing code by SMS so the signer's identity is verified before signing.
# Get these from twilio.com → Console. TWILIO_PHONE_NUMBER must be an SMS-capable Twilio number
# in E.164 format (e.g. +15551234567). Server-only — do NOT prefix with EXPO_PUBLIC_.
# Add in Railway → your service → Variables, then redeploy:
#   TWILIO_ACCOUNT_SID=ACxxxxxxxx
#   TWILIO_AUTH_TOKEN=your-twilio-auth-token
#   TWILIO_PHONE_NUMBER=+15551234567
# If these are unset, SMS verification is skipped automatically and signing still works
# (the admin's "Require SMS verification" toggle only takes effect once Twilio is configured).
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your-twilio-auth-token
TWILIO_PHONE_NUMBER=+15551234567

# ── Proxy → Stripe (billing / paywall; server-side only) ──
# The proxy creates Checkout sessions and handles the webhook with the SECRET key (never shipped to
# the app — the client opens the Checkout URL in the browser). If STRIPE_SECRET_KEY is unset the
# billing endpoints return 503 and the app falls back to the free trial, so dev works without Stripe.
# Create a $49/month recurring Product/Price in the Stripe dashboard to get STRIPE_PRICE_ID, and a
# webhook (event: checkout.session.completed) pointing at <proxy-url>/billing/webhook for the secret.
# Add in Railway → Variables, then redeploy (use sk_test_/price_ test values until going live):
#   STRIPE_SECRET_KEY=sk_test_...
#   STRIPE_PRICE_ID=price_...
#   STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key
STRIPE_PRICE_ID=price_your_49_per_month_price_id
# Optional annual ($490/year) recurring Price. If unset, the annual plan card is hidden in the app.
STRIPE_ANNUAL_PRICE_ID=price_your_490_per_year_price_id
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_signing_secret

# Public base URL of the deployed app (used for Stripe success/cancel redirects).
APP_URL=https://app.pricr.veraa.io

# ── Clean signing domain (server-side only) ──
# Base URL the proxy uses for signing-link self-references (the social/OG preview image, certificate
# links, and email links). Point a custom domain (e.g. sign.pricr.veraa.io) at the proxy and set this;
# falls back to the Railway URL if unset.
SIGN_BASE_URL=https://sign.pricr.veraa.io

# ── Veraa partner codes (server-side only) ──
# Optional JSON array of pre-approved Veraa partner codes (format VERAA-NAME-1234). The super-admin
# "Generate Code" tool writes new codes to the veraa_codes table (migration 0007); this env array is
# an additional fast-path/allowlist that works even before the table exists. Default: [].
VERAA_CODES=[]

# ── App (Expo) env vars ──
# Public base URL of the deployed proxy. Set this to your Railway URL.
EXPO_PUBLIC_PROXY_URL=https://your-railway-url.railway.app

# ── Supabase ──
# From Supabase project Settings → API. Without these, the app runs on local/demo flows only.
EXPO_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# ── Error monitoring (Sentry) ──
# Client DSN (React Native project) — enabled only in production builds. See README for setup.
EXPO_PUBLIC_SENTRY_DSN=https://xxxxx@oXXXX.ingest.sentry.io/XXXX
# Server DSN (proxy) — set in Railway. If unset, the proxy runs without Sentry.
SENTRY_DSN=https://xxxxx@oXXXX.ingest.sentry.io/XXXX

# ── Push notifications ──
# Expo project id (from `npx expo config --json | grep projectId` or the expo.dev dashboard).
EXPO_PUBLIC_PROJECT_ID=your-expo-project-id

# ── Owner (new-signup) notifications (server-side only) ──
# Where new-business signup notifications are emailed. Defaults to christian@veraa.io if unset.
OWNER_EMAIL=christian@veraa.io
# Your personal Expo push token for owner notifications (optional — gracefully skipped if unset).
# Get this by logging into the app and checking the Railway logs / browser console after login:
#   [Push] registered token: ExponentPushToken[xxxxxx]
# Copy that token and set it here in Railway.
# OWNER_PUSH_TOKEN=ExponentPushToken[xxxxxx]
