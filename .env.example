# ── Proxy server (proxy.js) env vars ──
# Port the proxy listens on. Railway sets PORT automatically; 3001 is the local default.
PORT=3001
# Anthropic API key the proxy injects into requests to api.anthropic.com (REQUIRED).
ANTHROPIC_KEY=sk-ant-...

# ── Proxy → Supabase (REMOTE SIGNING PAGE; server-side only) ──
# The proxy uses these to read a quote by its signing token and write the customer's
# signature back. The SERVICE ROLE key is secret — it lives ONLY on the server (Railway)
# and is NEVER shipped in the app or exposed to the browser. Do not put it in .env.local.
# Get them from Supabase → Settings → API (the service_role key, not the anon key).
#
# Add these in Railway → your service → Variables (do NOT prefix with EXPO_PUBLIC_):
#   SUPABASE_URL=https://your-project.supabase.co
#   SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOi...   (service_role secret)
# Then redeploy. The remote signing page lives at  <proxy-url>/sign/<signing_token>.
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ── App (Expo) env vars ──
# Public base URL of the deployed proxy. Set this to your Railway URL.
EXPO_PUBLIC_PROXY_URL=https://your-railway-url.railway.app

# ── Supabase ──
# From Supabase project Settings → API. Without these, the app runs on local/demo flows only.
EXPO_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
